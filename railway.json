# 告诉 Railway 使用 Docker 部署
{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "node dist/server/index.js",
    "healthcheckPath": "/api/styles",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE"
  }
}
